# SMZDM 好价提醒机器人 - 环境变量配置

# ========== 飞书配置 ==========
# 飞书自建应用机器人配置（推荐）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your-app-secret

# 通知目标通过私聊或群聊发送 /bind 自动绑定，不需要手动填写用户/群 ID
FEISHU_BINDING_FILE=workspace/state/feishu_binding.json

# ========== SMZDM 配置 ==========
# 必填：签名 key 和 User-Agent。示例文件不提供默认值，请参考 README 获取。
SMZDM_SIGN_KEY=
SMZDM_USER_AGENT=

# ========== LLM 配置 ==========
# LLM API Key
LLM_API_KEY=your-api-key

# LLM API Base URL（OpenAI 兼容接口）
# DeepSeek: https://api.deepseek.com/v1
# MiniMax: https://api.minimax.chat/v1
# GLM/智谱: https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=https://api.deepseek.com/v1

# LLM 模型名称
# DeepSeek: deepseek-chat
# MiniMax: MiniMax-M1
# GLM: glm-4-flash
LLM_MODEL=deepseek-chat

# OpenAI SDK 自动重试次数；SDK 会处理 429/5xx/连接抖动等可重试错误
LLM_MAX_RETRIES=2

# 主筛选 LLM 请求超时时间（秒）
LLM_TIMEOUT_SECONDS=300

# 启用双重判断模式（true/false）
# 开启后每次筛选会并发调用两次 LLM，比较结果；不一致时触发仲裁
LLM_DUAL_FILTER=false

# 启用仲裁 agent（true/false）
# 仅在 LLM_DUAL_FILTER=true 时生效，不一致时调用第三方 agent 裁决并推送分析
LLM_ARBITER_ENABLED=true

# 仲裁 LLM 配置（可选；不填则复用主 LLM 配置）
LLM_ARBITER_API_KEY=
LLM_ARBITER_BASE_URL=
LLM_ARBITER_MODEL=
LLM_ARBITER_TIMEOUT_SECONDS=

# 配置草案 LLM 配置（可选；不填则复用仲裁 LLM 配置）
# 用于偏好/库存自然语言草案和草案修订
LLM_DRAFT_API_KEY=
LLM_DRAFT_BASE_URL=
LLM_DRAFT_MODEL=
LLM_DRAFT_TIMEOUT_SECONDS=

# ========== 预筛选配置 ==========
# 机器层粗筛，减少明显低信号商品进入 LLM；偏好语义和专项门槛仍由 preference.md + LLM 判断
# 必须显式启用，下面阈值才会生效
PREFILTER_ENABLED=false

# 普通最低准入；预筛选启用后需全部满足
PREFILTER_MIN_WORTHY=0
PREFILTER_MIN_WORTHY_RATE=0
PREFILTER_MIN_COMMENTS=0
PREFILTER_MIN_FAVORITES=0

# 强信号直通；必须额外显式启用，命中后会忽略普通最低准入
PREFILTER_BYPASS_ENABLED=false
PREFILTER_BYPASS_MIN_COMMENTS=0
PREFILTER_BYPASS_MIN_WORTHY=0

# ========== 轮询配置 ==========
# 轮询间隔（分钟）
POLL_INTERVAL_MINUTES=30

# 无推送时发送心跳的间隔（小时）
HEARTBEAT_HOURS=6

# 不同榜单抓取间隔（秒）
FETCH_INTERVAL_SECONDS=5

# ========== 排行榜配置 ==========
# 每个榜单获取前 N 条
TOP_N=20

# 监控的榜单中文名，逗号分隔；留空则抓取全部内置榜单
# 可选：综合榜-全部, 综合榜-电脑数码, 综合榜-白菜, 综合榜-食品生鲜,
# 综合榜-运动户外, 综合榜-家用电器, 综合榜-服饰鞋包, 综合榜-日用百货,
# 综合榜-母婴用品, 综合榜-家居家装, 综合榜-办公设备, 综合榜-个护化妆,
# 综合榜-本地生活, 综合榜-医疗健康, 综合榜-图书文娱, 综合榜-玩模乐器,
# 热卖榜, 热评榜, 热搜榜
RANKING_NAMES=综合榜-全部,综合榜-食品生鲜,综合榜-电脑数码,综合榜-家用电器,综合榜-日用百货

# ========== 搜索关键词配置 ==========
# 独立 JSON 文件，格式参考 search_keywords.example.json；不存在时跳过搜索来源
SEARCH_KEYWORDS_FILE=search_keywords.json

# ========== 去重配置 ==========
# 去重过期时间（小时），同一商品在此时间内不重复推送
DEDUP_EXPIRE_HOURS=24
DEDUP_FILE=workspace/state/dedup_cache.json

# ========== 夜间汇总配置 ==========
DIGEST_HOUR=22
DIGEST_FILE=workspace/state/near_misses.json

# ========== 交互配置 ==========
# 偏好/库存修改草案、备份和审计日志路径
CONFIG_BACKUP_DIR=workspace/backups
CONFIG_DRAFT_FILE=workspace/state/pending_config_changes.json
CONFIG_AUDIT_FILE=workspace/audit/config_change_audit.jsonl

# ========== 日志配置 ==========
LOG_FILE_PATTERN=workspace/logs/smzdm_notice_{time:YYYY-MM-DD}.log
